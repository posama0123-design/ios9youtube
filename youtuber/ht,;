<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>YouTube Fullscreen</title>
    
    <link rel="manifest" href="./manifest.json">
    
    <link rel="apple-touch-icon" href="image_14fcbc.png">
    
    <meta name="theme-color" content="#ff0000">

    <style>
        body, html {
            margin: 0; padding: 0; height: 100%; width: 100%;
            overflow: hidden; background-color: #000;
        }
        iframe {
            position: absolute; top: 0; left: 0;
            width: 100%; height: 100%; border: none;
        }
        #launcher {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 999; background: rgba(0,0,0,0.8);
            display: flex; align-items: center; justify-content: center;
            color: white; font-family: sans-serif; cursor: pointer;
            text-align: center; padding: 20px; box-sizing: border-box;
        }
    </style>
</head>
<body>

    <div id="launcher">ここをクリックして<br>全画面でYouTubeを起動</div>
    <iframe id="yt" src="https://m.youtube.com" allow="fullscreen"></iframe>

    <script>
        const launcher = document.getElementById('launcher');
        const doc = document.documentElement;

        launcher.addEventListener('click', () => {
            // フル画面リクエスト
            if (doc.requestFullscreen) {
                doc.requestFullscreen();
            } else if (doc.webkitRequestFullscreen) {
                doc.webkitRequestFullscreen();
            }
            
            // 起動用レイヤーを消す
            launcher.style.display = 'none';
        });

        // Service Workerの登録 (PWAのインストールに必要)
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('./sw.js').then(reg => {
                    console.log('SW registered:', reg);
                }).catch(err => {
                    console.log('SW registration failed:', err);
                });
            });
        }
    </script>
</body>
</html>
